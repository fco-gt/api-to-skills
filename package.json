{
  "name": "api-to-skill",
  "version": "1.0.0",
  "description": "CLI tool that converts APIs and documentation into structured skill files for AI agents",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "api-to-skill": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "cli",
    "openapi",
    "swagger",
    "ai-agents",
    "skills",
    "claude",
    "tool-use"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@readme/openapi-parser": "^2.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "marked": "^14.0.0",
    "ora": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.10.0",
    "openapi-types": "^12.1.3",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
