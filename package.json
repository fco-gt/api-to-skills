{
  "name": "api-to-skill",
  "version": "1.0.0",
  "description": "CLI tool that converts APIs and documentation into structured skill files for AI agents",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "api-to-skill": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "cli",
    "openapi",
    "swagger",
    "ai-agents",
    "skills",
    "claude",
    "tool-use"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@readme/openapi-parser": "^2.7.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "js-yaml": "^4.1.1",
    "marked": "^14.1.4",
    "ora": "^8.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.16.2",
    "openapi-types": "^12.1.3",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.9"
  }
}
